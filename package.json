{
    "name": "pinnacle",
    "version": "1.1.3",
    "description": "Cross-platform PDF management app built with Rust and Tauri",
    "scripts": {
        "tauri": "tauri",
        "dev": "tauri dev",
        "build": "tauri build",
        "build:mac": "tauri build",
        "build:win": "tauri build --target x86_64-pc-windows-msvc",
        "build:linux": "tauri build --target x86_64-unknown-linux-gnu",
        "build:ios": "tauri ios build",
        "dev:ios": "tauri ios dev",
        "build:android": "tauri android build",
        "dev:android": "tauri android dev",
        "test:backend": "cargo test --manifest-path src-tauri/Cargo.toml -- --test-threads=1",
        "test:ui": "npm --prefix src/ui run test:ui",
        "test:e2e": "npm --prefix src/ui run test:e2e",
        "test": "npm run test:backend && npm run test:ui && npm run test:e2e",
        "release": "standard-version",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.11.1",
        "standard-version": "^9.5.0",
        "vitepress": "^1.6.4"
    },
    "keywords": [
        "tauri",
        "rust",
        "pdf",
        "svelte",
        "cross-platform"
    ],
    "author": "Prashant Bansal",
    "license": "MIT",
    "packageManager": "pnpm@10.6.5+sha512.cdf928fca20832cd59ec53826492b7dc25dc524d4370b6b4adbf65803d32efaa6c1c88147c0ae4e8d579a6c9eec715757b50d4fa35eea179d868eada4ed043af"
}
